@startuml dfd
skinparam rectangle {
  BackgroundColor LightYellow
  BorderColor DarkOrange
}
skinparam database {
  BackgroundColor LightBlue
  BorderColor Navy
}
title Data Flow Diagram — Level 0 + Level 1

' ── External Entities ──────────────────────────────
actor "Employee"        as EMP
actor "HR / Admin"      as HR
actor "Camera Device"   as CAM
actor "Manager"         as MGR

' ── Main Process (Level 0 boundary) ────────────────
rectangle "FaceID\nAttendance System" as SYS #LightGreen

EMP --> SYS : Face image / Login
CAM --> SYS : RTSP video stream
HR  --> SYS : Employee data / Approvals
SYS --> EMP : Attendance status / Leave result
SYS --> HR  : Reports / Alerts
SYS --> MGR : Pending leave list

' ── Level 1 Decomposition ───────────────────────────
package "Level 1 Processes" {
  rectangle "P1\nAuthentication"      as P1
  rectangle "P2\nFace Recognition"   as P2
  rectangle "P3\nAttendance Engine"  as P3
  rectangle "P4\nLeave Management"   as P4
  rectangle "P5\nReport Generator"   as P5

  database  "D1 users"               as D1
  database  "D2 employees"           as D2
  database  "D3 face_data"           as D3
  database  "D4 attendance_records"  as D4
  database  "D5 leave_requests"      as D5
}

EMP --> P1 : credentials
P1  --> D1 : verify hash
D1  --> P1 : user record
P1  --> EMP : session token

CAM --> P2 : frame
P2  --> D3 : load encodings
D3  --> P2 : 128-D vectors
P2  --> P3 : matched employee_id + confidence

P3  --> D4 : write check_in / check_out
P3  --> D2 : read shift schedule
D4  --> P5 : attendance data

EMP --> P4 : leave request
P4  --> D5 : save request
MGR --> P4 : approve/reject
P4  --> D2 : update used_leave_days

D4  --> P5 : records
D5  --> P5 : leave data
P5  --> HR  : monthly report

@enduml
