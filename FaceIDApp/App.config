<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="DATABASE_URL" value="postgresql://postgres:1234@localhost:5432/face_attendance" />
    <add key="PostgresDatabaseName" value="face_attendance" />
    <add key="ModelsDirectory" value="models" />
  </appSettings>
  <connectionStrings>
    <add name="PostgresAdmin" connectionString="Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=1234;Pooling=true;" />
  </connectionStrings>
</configuration>